@model GRA.Controllers.ViewModel.MissionControl.Categories.CategoryListViewModel

@section inHeading {
    <div class="ms-auto d-print-none">
        <a class="btn btn-outline-success"
           data-bs-toggle="modal"
           data-bs-target="#addModal">
            <span class="fas fa-plus-circle fa-fw"></span>
            Add a Category
        </a>
    </div>
}

<form asp-controller="Categories" asp-action="Index" method="get" role="form">
    <div class="row my-3">
        <div class="col-12 input-group">
            <input asp-for="Search"
                   class="form-control"
                   placeholder="Search for category" />
            <a asp-action="@nameof(CategoriesController.Index)"
               class="btn btn-outline-secondary">Clear</a>
            <input type="submit" value="Search" class="btn btn-outline-primary" />
        </div>
    </div>
</form>

<div class="row">
    <div class="col-12">
        @if (Model.Categories.Count() == 0)
        {
            <div class="alert alert-warning">No Categories</div>
        }
        else
        {
            <div>
                <table class="table table-sm table-bordered table-striped">
                    <thead>
                        <tr>
                            <th>Name</th>
                            <th>Description</th>
                            <th>Preview</th>
                            <th>Contrast</th>
                            <th style="width: 7rem;">&nbsp;</th>
                        </tr>
                    </thead>
                    <tbody>
                        @foreach (var category in Model.Categories)
                        {
                            <tr>
                                <td>
                                    @category.Name
                                </td>
                                <td>
                                    @category.Description
                                </td>
                                <td>
                                    <span class="badge"
                                          style="background-color: @category.Color">
                                        @category.Name
                                    </span>
                                </td>
                                <td class="category-contrast" data-bg="@category.Color">
                                    <span class="contrast-value"></span>
                                    <span class="contrast-compliance ms-2"></span>
                                </td>
                                <td>
                                    <div class="d-flex justify-content-evenly">
                                        <button type="button"
                                                class="btn btn-outline-primary btn-sm"
                                                data-bs-toggle="modal"
                                                data-bs-target="#editModal"
                                                data-id="@category.Id"
                                                data-name="@category.Name"
                                                data-description="@category.Description"
                                                data-color="@category.Color">
                                            <span class="fas fa-pencil-alt fa-fw"
                                                  aria-hidden="true"></span>
                                        </button>
                                        <button type="button"
                                                class="btn btn-outline-danger btn-sm"
                                                data-bs-toggle="modal"
                                                data-bs-target="#deleteModal"
                                                data-id="@category.Id"
                                                data-name="@category.Name">
                                            <span class="fas fa-times fa-fw"
                                                  aria-hidden="true"></span>
                                        </button>
                                    </div>
                                </td>
                            </tr>
                        }
                    </tbody>
                </table>
            </div>
            <paginate paginateModel="@Model.PaginateModel"></paginate>
        }
    </div>
</div>

<div class="modal fade"
     id="addModal"
     tabindex="-1"
     role="dialog"
     aria-labelledby="addModalLabel">
    <div class="modal-dialog" role="document">
        <form asp-controller="Categories"
              asp-action="Add"
              method="post"
              role="form"
              style="display:inline">
            <input asp-for="PaginateModel.CurrentPage" type="hidden" />
            <input asp-for="Search" type="hidden" />
            <div class="modal-content">
                <div class="modal-header">
                    <h1 class="modal-title h4" id="addModalLabel">Add Category</h1>
                    <button type="button"
                            class="btn-close"
                            data-bs-dismiss="modal"
                            aria-label="Close dialog">
                    </button>
                </div>
                <div class="modal-body">
                    <div>
                        <label asp-for="Category.Name" class="col-form-label"></label>
                        <input asp-for="Category.Name" class="form-control" />
                        <span asp-validation-for="Category.Name" class="text-danger"></span>
                    </div>
                    <div>
                        <label asp-for="Category.Description" class="col-form-label"></label>
                        <input asp-for="Category.Description" class="form-control" />
                        <span asp-validation-for="Category.Description"
                              class="text-danger"></span>
                    </div>
                    <div>
                        <label asp-for="Category.Color" class="col-form-label"></label>
                        <input asp-for="Category.Color"
                               class="d-block"
                               type="color"
                               value="#777777" />
                               <div class="mt-2 contrast-status">
                                   <small>
                                       Contrast ratio: <span class="contrast-ratio"></span>
                                       <span class="contrast-pass ms-2"></span>
                                   </small>
                               </div>
                        <span asp-validation-for="Category.Color" class="text-danger"></span>
                    </div>
                </div>
                <div class="modal-footer">
                    <button type="button"
                            class="btn btn-outline-secondary"
                            data-bs-dismiss="modal">
                        Cancel
                    </button>
                    <button type="submit"
                            class="btn btn-outline-primary"
                            aria-label="Confirm"
                            button-spinner>
                        Add
                    </button>
                </div>
            </div>
        </form>
    </div>
</div>

<div class="row">
    <div class="modal fade"
         id="editModal"
         tabindex="-1"
         role="dialog"
         aria-labelledby="editModalLabel">
        <div class="modal-dialog" role="document">
            <form asp-controller="Categories"
                  asp-action="Edit"
                  method="post"
                  role="form"
                  style="display:inline">
                <input asp-for="PaginateModel.CurrentPage" type="hidden" />
                <input asp-for="Search" type="hidden" />
                <input asp-for="Category.Id" type="hidden" />
                <div class="modal-content">
                    <div class="modal-header">
                        <h1 class="modal-title h4" id="editModalLabel">Edit Category</h1>
                        <button type="button"
                                class="btn-close"
                                data-bs-dismiss="modal"
                                aria-label="Close dialog">
                        </button>
                    </div>
                    <div class="modal-body">
                        <div>
                            <label asp-for="Category.Name" class="col-form-label"></label>
                            <input asp-for="Category.Name" class="form-control" />
                            <span asp-validation-for="Category.Name" class="text-danger"></span>
                        </div>
                        <div>
                            <label asp-for="Category.Description" class="col-form-label"></label>
                            <input asp-for="Category.Description" class="form-control" />
                            <span asp-validation-for="Category.Description"
                                  class="text-danger"></span>
                        </div>
                        <div>
                            <label asp-for="Category.Color" class="col-form-label"></label>
                            <input asp-for="Category.Color" class="d-block" type="color" />
                            <div class="mt-2 contrast-status">
                                <small>
                                    Contrast ratio: <span class="contrast-ratio"></span>
                                    <span class="contrast-pass ms-2"></span>
                                </small>
                            </div>
                            <span asp-validation-for="Category.Color"
                                  class="text-danger"></span>
                        </div>
                    </div>
                    <div class="modal-footer">
                        <button type="button"
                                class="btn btn-outline-secondary"
                                data-bs-dismiss="modal">
                            Cancel
                        </button>
                        <button type="submit"
                                class="btn btn-outline-primary"
                                aria-label="Confirm"
                                button-spinner>
                            Save
                        </button>
                    </div>
                </div>
            </form>
        </div>
    </div>
</div>

<div class="modal fade"
     id="deleteModal"
     tabindex="-1"
     role="dialog"
     aria-labelledby="deleteModalLabel">
    <div class="modal-dialog" role="document">
        <form asp-controller="Categories"
              asp-action="Delete"
              method="post"
              role="form"
              style="display:inline">
            <input asp-for="PaginateModel.CurrentPage" type="hidden" />
            <input asp-for="Search" type="hidden" />
            <input asp-for="Category.Id" type="hidden" />
            <input asp-for="Category.Name" type="hidden" />
            <div class="modal-content">
                <div class="modal-header">
                    <h1 class="modal-title h4" id="deleteModalLabel">Delete Category</h1>
                    <button type="button"
                            class="btn-close"
                            data-bs-dismiss="modal"
                            aria-label="Close dialog">
                    </button>
                </div>
                <div class="modal-body p-0">
                    <div class="modal-body d-flex align-items-stretch">
                        <span class="fas fa-exclamation-triangle fa-lg text-danger pt-2 me-3"
                              aria-hidden="true"></span>
                        <span id="modal-text"></span>
                    </div>
                </div>
                <div class="modal-footer">
                    <button type="button"
                            class="btn btn-outline-secondary"
                            data-bs-dismiss="modal"
                            style="margin-right: 1em;">
                        Cancel
                    </button>
                    <button type="submit"
                            class="btn btn-outline-danger btn-spinner float-end"
                            aria-label="Confirm"
                            button-spinner>
                        <span class="fas fa-times fa-fw" aria-hidden="true"></span>
                        Delete
                    </button>
                </div>
            </div>
        </form>
    </div>
</div>

@section scripts {
    <script>
        $("#editModal").on("show.bs.modal", function (e) {
            const button = $(e.relatedTarget);
            const id = button.data("id");
            const name = button.data("name");
            const description = button.data("description");
            const color = button.data("color");
            const modal = $(this);
            modal.find("#editModalLabel").text("Edit Category - \"" + name + "\"");
            modal.find("#Category_Id").val(id);
            modal.find("#Category_Name").val(name);
            modal.find("#Category_Description").val(description);
            modal.find("#Category_Color").val(color);
        });

        $("#deleteModal").on("show.bs.modal", function (e) {
            const button = $(e.relatedTarget);
            const id = button.data("id");
            const name = button.data("name");
            const modal = $(this);
            modal.find("#modal-text").html("Are you sure you wish to delete the Category <strong>" + name + "</strong>?");
            modal.find("#Category_Id").val(id);
            modal.find("#Category_Name").val(name);
        });

        /**
        *
        * This converts contrast to the required ratio using relative luminence
        * instead of hue as per WCAG 2.1
        *
        * Necessary steps:
        *
        * 1. Parse each selected color into 8-bit sRGV channels, then normalize to [0,1]:
        *      c_srgb = c8/255
        *
        * 2. Convert each normalized sRGB channel to linear-light (undo gamma):
        *      if c_srgb <= 0.04045:
        *          c_lin = c_srgb / 12.92
        *      else:
        *          c_lin = ((c_srgb + 0.055) / 1.055) ^2.4
        *
        * 3. Compute L (relative luminance) for each color:
        *      L = 0.2126*R_lin + 0.7152*G_lin + 0.0722*B_lin
        *
        * 4. Compute contrast ratio:
        *      ratio = (L1 + 0.05) / (L2 + 0.05)
        *    where L1 is lighter and L2 is darker
        *
        *
        * 5. This is then expressed as a ratio
        */

        function hexToRgb(hex) 
        {
            if (!hex) return null;
            const h = String(hex).trim().replace(/^#/, "");
            if (!/^[0-9a-fA-F]{6}$/.test(h)) return null;

            return {
                r: parseInt(h.slice(0, 2), 16),
                g: parseInt(h.slice(2, 4), 16),
                b: parseInt(h.slice(4, 6), 16),
            };
        }

        function srgb8ToLinear(c8) {
            const c = c8 / 255;
            return c <= 0.04045 ? c / 12.92 : Math.pow((c + 0.055) / 1.055, 2.4);
        }

        function relativeLuminance(hex) {
            const rgb = typeof hex === "string" ? hexToRgb(hex) : hex;
            if (!rgb) return null;

            const R = srgb8ToLinear(rgb.r);
            const G = srgb8ToLinear(rgb.g);
            const B = srgb8ToLinear(rgb.b);

            return 0.2126 * R + 0.7152 * G + 0.0722 * B;
        }

        function contrastRatio(colorA, colorB) {
            const LA = relativeLuminance(colorA);
            const LB = relativeLuminance(colorB);
            if (LA == null || LB == null) return null;

            const lighter = Math.max(LA, LB);
            const darker = Math.min(LA, LB);

            return (lighter + 0.05) / (darker + 0.05);
        }

        function meetsMinRatio(colorA, colorB, minRatio = 4.5) {
            const ratio = contrastRatio(colorA, colorB);
            return ratio != null && ratio >= minRatio;
        }

        const WCAG_MIN_RATIO = 4.5;
        // bs-badge-color is white by default
        const CATEGORY_TEXT_COLOR = "#ffffff";

        function updateContrastStatus($modal, fgHex, bgHex) {
            const ratio = contrastRatio(fgHex, bgHex);

            const $ratio = $modal.find(".contrast-ratio");
            const $pass = $modal.find(".contrast-pass");

            if (ratio == null) {
                $ratio.text("–");
                $pass.text("").removeClass("text-success text-danger");
                return { ratio: null, passes: false };
            }

            const passes = ratio >= WCAG_MIN_RATIO;

            $ratio.text(ratio.toFixed(2) + ":1");
            $pass
                .text(passes ? "Passes WCAG requirements" : "Fails WCAG requirements")
                .toggleClass("text-success", passes)
                .toggleClass("text-danger", !passes);

            return { ratio, passes };
        }

        function bindModalColorContrast(modalSelector, inputSelector, fgHex) {
            const $modal = $(modalSelector);
            const $input = $modal.find(inputSelector);

            function recompute() {
                updateContrastStatus($modal, fgHex, $input.val());
            }

            $input.on("change", recompute);

            $input.on("input", recompute);

            $modal.on("shown.bs.modal", recompute);
        }

        bindModalColorContrast("#addModal", "#Category_Color", CATEGORY_TEXT_COLOR);
        bindModalColorContrast("#editModal", "#Category_Color", CATEGORY_TEXT_COLOR);

        $("#editModal").on("show.bs.modal", function () {
            const $modal = $(this);
            setTimeout(function () {
                updateContrastStatus($modal, CATEGORY_TEXT_COLOR, $modal.find("#Category_Color").val());
            }, 0);
        });

        function updateCategoryRowContrast($cell) {
            const bg = $cell.data("bg");
            const ratio = contrastRatio(CATEGORY_TEXT_COLOR, bg);

            const $value = $cell.find(".contrast-value");
            const $status = $cell.find(".contrast-compliance");

            if (ratio == null) {
                $value.text("–");
                $status.text("").removeClass("text-success text-danger");
                return;
            }

            const passes = ratio >= WCAG_MIN_RATIO;
            $value.text(ratio.toFixed(2) + ":1");
            $status
                .text(passes ? "Passes WCAG requirements" : "Fails WCAG requirements")
                .removeClass("text-success text-danger")
                .addClass(passes ? "text-success" : "text-danger");
        }

        function updateCategoryTableContrast() {
            $(".category-contrast").each(function () {
                updateCategoryRowContrast($(this));
            });
        }

        $(updateCategoryTableContrast);

    </script>
}