@model GRA.Controllers.ViewModel.MissionControl.Categories.CategoryListViewModel

@section inHeading {
    <div class="ms-auto d-print-none">
        <a class="btn btn-outline-success"
           data-bs-toggle="modal"
           data-bs-target="#addModal">
            <span class="fas fa-plus-circle fa-fw"></span>
            Add a Category
        </a>
    </div>
}

<form asp-controller="Categories" asp-action="Index" method="get" role="form">
    <div class="row my-3">
        <div class="col-12 input-group">
            <input asp-for="Search"
                   class="form-control"
                   placeholder="Search for category" />
            <a asp-action="@nameof(CategoriesController.Index)"
               class="btn btn-outline-secondary">Clear</a>
            <input type="submit" value="Search" class="btn btn-outline-primary" />
        </div>
    </div>
</form>

<div class="row">
    <div class="col-12">
        @if (Model.Categories.Count() == 0)
        {
            <div class="alert alert-warning">No Categories</div>
        }
        else
        {
            <div>
                <table class="table table-sm table-bordered table-striped">
                    <thead>
                        <tr>
                            <th>Name</th>
                            <th>Description</th>
                            <th>Preview</th>
                            <th>
                                Contrast
                                (min. @GRA.Utility.ColorConstants.Wcag21AaContrastRatioMinimum:1)
                            </th>
                            <th>&nbsp;</th>
                        </tr>
                    </thead>
                    <tbody>
                        @foreach (var category in Model.Categories)
                        {
                            <tr>
                                <td>
                                    @category.Name
                                </td>
                                <td>
                                    @category.Description
                                </td>
                                <td>
                                    <span class="badge"
                                          style="background-color: @category.Color">
                                        @category.Name
                                    </span>
                                </td>
                                <td class="text-center">
                                    <span class="badge @(category.MeetsWCAG21AAContrastRequirement ? "text-bg-success" : "text-bg-danger") me-2">AA</span>
                                    <span>@($"{category.ContrastRatio:n1}:1")</span>
                                </td>
                                <td>
                                    <div class="d-flex justify-content-evenly">
                                        <button type="button"
                                                class="btn btn-outline-primary btn-sm"
                                                data-bs-toggle="modal"
                                                data-bs-target="#editModal"
                                                data-id="@category.Id"
                                                data-name="@category.Name"
                                                data-description="@category.Description"
                                                data-color="@category.Color">
                                            <span class="fas fa-pencil-alt fa-fw"
                                                  aria-hidden="true"></span>
                                        </button>
                                        <button type="button"
                                                class="btn btn-outline-danger btn-sm"
                                                data-bs-toggle="modal"
                                                data-bs-target="#deleteModal"
                                                data-id="@category.Id"
                                                data-name="@category.Name">
                                            <span class="fas fa-times fa-fw"
                                                  aria-hidden="true"></span>
                                        </button>
                                    </div>
                                </td>
                            </tr>
                        }
                    </tbody>
                </table>
            </div>
            <paginate paginateModel="@Model.PaginateModel"></paginate>
        }
    </div>
</div>

<div class="modal fade"
     id="addModal"
     tabindex="-1"
     role="dialog"
     aria-labelledby="addModalLabel">
    <div class="modal-dialog" role="document">
        <form asp-controller="Categories"
              asp-action="Add"
              method="post"
              role="form"
              style="display:inline">
            <input asp-for="PaginateModel.CurrentPage" type="hidden" />
            <input asp-for="Search" type="hidden" />
            <div class="modal-content">
                <div class="modal-header">
                    <h1 class="modal-title h4" id="addModalLabel">Add Category</h1>
                    <button type="button"
                            class="btn-close"
                            data-bs-dismiss="modal"
                            aria-label="Close dialog">
                    </button>
                </div>
                <div class="modal-body">
                    <div>
                        <label asp-for="Category.Name" class="col-form-label"></label>
                        <input asp-for="Category.Name" class="form-control" />
                        <span asp-validation-for="Category.Name" class="text-danger"></span>
                    </div>
                    <div>
                        <label asp-for="Category.Description" class="col-form-label"></label>
                        <input asp-for="Category.Description" class="form-control" />
                        <span asp-validation-for="Category.Description"
                              class="text-danger"></span>
                    </div>
                    <div>
                        <label asp-for="Category.Color" class="col-form-label"></label>
                        <input asp-for="Category.Color"
                               id="addCategoryColor"
                               class="d-block"
                               type="color"
                               value="@GRA.Utility.ColorConstants.DefaultColor" />
                        <div class="contrast-status">
                            <label class="contrast-label">
                                Contrast ratio <em>
                                    (min.
                                    @GRA.Utility.ColorConstants.Wcag21AaContrastRatioMinimum:1)
                                </em>:
                                <span class="contrast-ratio fw-bold"></span>
                            </label>
                            <span class="contrast-pass badge ms-2">AA</span>
                        </div>
                        <span asp-validation-for="Category.Color" class="text-danger"></span>
                    </div>
                </div>
                <div class="modal-footer">
                    <button type="button"
                            class="btn btn-outline-secondary"
                            data-bs-dismiss="modal">
                        Cancel
                    </button>
                    <button type="submit"
                            class="btn btn-outline-primary save-button"
                            aria-label="Confirm"
                            button-spinner>
                        Add
                    </button>
                </div>
            </div>
        </form>
    </div>
</div>

<div class="row">
    <div class="modal fade"
         id="editModal"
         tabindex="-1"
         role="dialog"
         aria-labelledby="editModalLabel">
        <div class="modal-dialog" role="document">
            <form asp-controller="Categories"
                  asp-action="Edit"
                  method="post"
                  role="form"
                  style="display:inline">
                <input asp-for="PaginateModel.CurrentPage" type="hidden" />
                <input asp-for="Search" type="hidden" />
                <input asp-for="Category.Id" type="hidden" />
                <div class="modal-content">
                    <div class="modal-header">
                        <h1 class="modal-title h4" id="editModalLabel">Edit Category</h1>
                        <button type="button"
                                class="btn-close"
                                data-bs-dismiss="modal"
                                aria-label="Close dialog">
                        </button>
                    </div>
                    <div class="modal-body">
                        <div>
                            <label asp-for="Category.Name" class="col-form-label"></label>
                            <input asp-for="Category.Name" class="form-control" />
                            <span asp-validation-for="Category.Name" class="text-danger"></span>
                        </div>
                        <div>
                            <label asp-for="Category.Description" class="col-form-label"></label>
                            <input asp-for="Category.Description" class="form-control" />
                            <span asp-validation-for="Category.Description"
                                  class="text-danger"></span>
                        </div>
                        <div>
                            <label asp-for="Category.Color" class="col-form-label"></label>
                            <input asp-for="Category.Color"
                                   class="d-block"
                                   id="updateCategoryColor"
                                   type="color" />
                            <div class="contrast-status">
                                <label class="contrast-label">
                                    Contrast ratio <em>
                                        (min.
                                        @GRA.Utility.ColorConstants.Wcag21AaContrastRatioMinimum:1)
                                    </em>:
                                    <span class="contrast-ratio fw-bold"></span>
                                </label>
                                <span class="contrast-pass badge ms-2">AA</span>
                            </div>
                            <span asp-validation-for="Category.Color"
                                  class="text-danger"></span>
                        </div>
                    </div>
                    <div class="modal-footer">
                        <button type="button"
                                class="btn btn-outline-secondary"
                                data-bs-dismiss="modal">
                            Cancel
                        </button>
                        <button type="submit"
                                class="btn btn-outline-primary save-button"
                                aria-label="Confirm"
                                button-spinner>
                            Save
                        </button>
                    </div>
                </div>
            </form>
        </div>
    </div>
</div>

<div class="modal fade"
     id="deleteModal"
     tabindex="-1"
     role="dialog"
     aria-labelledby="deleteModalLabel">
    <div class="modal-dialog" role="document">
        <form asp-controller="Categories"
              asp-action="Delete"
              method="post"
              role="form"
              style="display:inline">
            <input asp-for="PaginateModel.CurrentPage" type="hidden" />
            <input asp-for="Search" type="hidden" />
            <input asp-for="Category.Id" type="hidden" />
            <input asp-for="Category.Name" type="hidden" />
            <div class="modal-content">
                <div class="modal-header">
                    <h1 class="modal-title h4" id="deleteModalLabel">Delete Category</h1>
                    <button type="button"
                            class="btn-close"
                            data-bs-dismiss="modal"
                            aria-label="Close dialog">
                    </button>
                </div>
                <div class="modal-body p-0">
                    <div class="modal-body d-flex align-items-stretch">
                        <span class="fas fa-exclamation-triangle fa-lg text-danger pt-2 me-3"
                              aria-hidden="true"></span>
                        <span id="modal-text"></span>
                    </div>
                </div>
                <div class="modal-footer">
                    <button type="button"
                            class="btn btn-outline-secondary"
                            data-bs-dismiss="modal"
                            style="margin-right: 1em;">
                        Cancel
                    </button>
                    <button type="submit"
                            class="btn btn-outline-danger btn-spinner float-end"
                            aria-label="Confirm"
                            button-spinner>
                        <span class="fas fa-times fa-fw" aria-hidden="true"></span>
                        Delete
                    </button>
                </div>
            </div>
        </form>
    </div>
</div>

@section scripts {
    <script>
        $("#editModal").on("show.bs.modal", function (e) {
            const button = $(e.relatedTarget);
            const id = button.data("id");
            const name = button.data("name");
            const description = button.data("description");
            const color = button.data("color");
            const modal = $(this);
            modal.find("#editModalLabel").text("Edit Category - \"" + name + "\"");
            modal.find("#Category_Id").val(id);
            modal.find("#Category_Name").val(name);
            modal.find("#Category_Description").val(description);
            modal.find("#updateCategoryColor").val(color);
        });

        $("#deleteModal").on("show.bs.modal", function (e) {
            const button = $(e.relatedTarget);
            const id = button.data("id");
            const name = button.data("name");
            const modal = $(this);
            modal.find("#modal-text").html("Are you sure you wish to delete the Category <strong>" + name + "</strong>?");
            modal.find("#Category_Id").val(id);
            modal.find("#Category_Name").val(name);
        });
        const enforceA11y = "@Model.EnforceA11y";
        const graContrastUrl = new URL(`${location.origin}@Url.Action(nameof(HomeController.ContrastRatio), HomeController.Name, new { area = HomeController.Area })`);

        if(typeof graContrastUrl !== 'undefined' && graContrastUrl) {
            // returns an object with these properties:
            // ratio = what the contrast ratio is
            // meetsWCAG21AA = meets the WCAG 2.1 AA contrast requirement
            function contrastRatio(rgbHexadecimal1, rgbHexadecimal2) {
                graContrastUrl.search = new URLSearchParams({
                    rgbHexadecimal1: rgbHexadecimal1,
                    rgbHexadecimal2: rgbHexadecimal2
                });

                try {
                    return fetch(graContrastUrl).then((response) => response.json());
                }
                catch (e) {
                    console.error(`An issue occured checking contrast: ${e}`);
                    alert(`An issue occured checking contrast: ${e}`);
                }
            }

            function updateContrastStatus($modal, rgbHexadecimal1, rgbHexadecimal2) {
                contrastRatio(rgbHexadecimal1, rgbHexadecimal2)
                    .then((contrastResult) => {
                        const $ratio = $modal.find(".contrast-ratio");
                        const $pass = $modal.find(".contrast-pass");
                        const $save = $modal.find(".save-button");
                        const $contrastLabel = $modal.find(".contrast-label");

                        if (contrastResult.ratio == null) {
                            $ratio.text("–");
                            $pass.text("").removeClass("text-success text-danger");
                        }

                        $ratio.text(`${contrastResult.ratio.toFixed(1)}:1`);
                        $pass.toggleClass("text-bg-success", contrastResult.meetsWCAG21AA)
                            .toggleClass("text-bg-danger", !contrastResult.meetsWCAG21AA);

                        if(enforceA11y && enforceA11y === "True") {
                            $save.toggleClass("btn-outline-success", contrastResult.meetsWCAG21AA)
                                .toggleClass("btn-outline-danger", !contrastResult.meetsWCAG21AA);
                            $contrastLabel.toggleClass("text-danger", !contrastResult.meetsWCAG21AA);
                            if(contrastResult.meetsWCAG21AA) {
                                $save.attr("disabled", null);
                            }
                            else {
                                $save.attr("disabled", "disabled");
                            }
                        }
                    });
            }

            const whiteBackgroundColor = "@GRA.Utility.ColorConstants.WhiteBackground";

            function bindContrastCheck() {
                const $addModal = $("#addModal");
                const $addInput = $addModal.find("#addCategoryColor");

                if ($addModal.length !== 0 && $addInput.length !== 0) {
                    function recompute() {
                        updateContrastStatus($addModal, $addInput.val(), whiteBackgroundColor);
                    }
                    
                    $addInput.off("change.contrast input.contrast");
                    $addModal.off("shown.bs.modal.contrast");

                    $addInput.on("change.contrast", recompute);
                    $addInput.on("input.contrast", recompute);
                    $addModal.on("shown.bs.modal.contrast", recompute);
                    
                    recompute();
                }

                const $editModal = $("#editModal");
                const $editInput = $editModal.find("#updateCategoryColor");

                if ($editModal.length !== 0 && $editInput.length !== 0) {
                    function recompute() {
                        updateContrastStatus($editModal, $editInput.val(), whiteBackgroundColor);
                    }

                    $editInput.off("change.contrast input.contrast");
                    $editModal.off("shown.bs.modal.contrast");

                    $editInput.on("change.contrast", recompute);
                    $editInput.on("input.contrast", recompute);
                    $editModal.on("shown.bs.modal.contrast", recompute);

                    recompute();
                }
            }
            bindContrastCheck();
        }
    </script>
}