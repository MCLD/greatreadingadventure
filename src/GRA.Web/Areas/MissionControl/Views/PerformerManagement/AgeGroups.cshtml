@model GRA.Controllers.ViewModel.MissionControl.PerformerManagement.AgeGroupsListViewModel

@await Html.PartialAsync("_PerformerManagementPartial")

<div class="row my-4">
    <div class="col-12 col-md-8 offset-md-2 col-xl-6 offset-xl-3">
        <a class="btn btn-outline-primary"
           data-bs-toggle="modal"
           data-bs-target="#addModal">Add an Age Group</a>
    </div>
</div>

<div class="row">
    <div class="col-12 col-md-8 offset-md-2 col-xl-6 offset-xl-3">
        @if (Model.AgeGroups.Count == 0)
        {
            <div class="alert alert-warning">No Age Groups</div>
        }
        else
        {
            <div>
                <table class="table table-sm table-bordered table-striped">
                    <thead>
                        <tr>
                            <th>Name</th>
                            <th>Color</th>
                            <th>Back to Back Branches</th>
                            <th style="width: 6rem;">&nbsp;</th>
                        </tr>
                    </thead>
                    <tbody>
                        @foreach (var AgeGroup in Model.AgeGroups)
                        {
                            <tr>
                                <td>
                                    @AgeGroup.Name
                                </td>

                                <td>
                                    <span class="fas fa-square" style="color: @AgeGroup.IconColor"></span>
                                </td>
                                <td>
                                    @AgeGroup.BackToBackBranchIds.Count
                                </td>
                                <td class="text-center">
                                    <button type="button"
                                            class="btn btn-outline-primary btn-sm"
                                            data-bs-toggle="modal"
                                            data-bs-target="#updateBackToBackModal"
                                            data-id="@AgeGroup.Id"
                                            data-name="@AgeGroup.Name"
                                            data-branchids="@string.Join(",", AgeGroup.BackToBackBranchIds)">
                                        <span class="fas fa-pencil-alt fa-fw" aria-hidden="true"></span>
                                    </button>
                                    <button type="button"
                                            class="btn btn-outline-danger btn-sm"
                                            data-bs-toggle="modal"
                                            data-bs-target="#deleteModal"
                                            data-id="@AgeGroup.Id"
                                            data-name="@AgeGroup.Name">
                                        <span class="fas fa-times fa-fw" aria-hidden="true"></span>
                                    </button>
                                </td>
                            </tr>
                        }
                    </tbody>
                </table>
            </div>
            <paginate paginateModel="@Model.PaginateModel"></paginate>
        }
    </div>
</div>

<div class="row">
    <div class="modal fade"
         id="addModal"
         tabindex="-1"
         role="dialog"
         aria-labelledby="addModalLabel">
        <div class="modal-dialog" role="document">
            <form asp-controller="PerformerManagement"
                  asp-action="AddAgeGroup"
                  method="post"
                  role="form"
                  style="display:inline">
                <input asp-for="PaginateModel.CurrentPage" type="hidden" />
                <div class="modal-content">
                    <div class="modal-header">
                        <h1 class="modal-title h4" id="addModalLabel">Add Age Group</h1>
                        <button type="button"
                                class="btn-close"
                                data-bs-dismiss="modal"
                                aria-label="Close dialog">
                        </button>
                    </div>
                    <div class="modal-body">
                        <div class="mb-3">
                            <label asp-for="AgeGroup.Name" class="col-form-label"></label>
                            <input asp-for="AgeGroup.Name" class="form-control" />
                            <span asp-validation-for="AgeGroup.Name" class="text-danger"></span>
                        </div>
                        <div class="mb-3">
                            <label asp-for="AgeGroup.IconColor" class="col-form-label"></label>
                            <description gra-description-for="AgeGroup.IconColor"></description>
                            <br />
                            <input asp-for="AgeGroup.IconColor" type="color" />
                            <div class="mt-2 contrast-status">
                                <small>
                                    Contrast ratio: <span class="contrast-ratio"></span>
                                    <span class="contrast-pass ms-2"></span>
                                </small>
                            </div>
                            <span asp-validation-for="AgeGroup.IconColor"
                                  class="text-danger"></span>
                        </div>
                    </div>
                    <div class="modal-footer">
                        <button type="button"
                                class="btn btn-outline-secondary"
                                data-bs-dismiss="modal"
                                style="margin-right: 1em;">
                            Cancel
                        </button>
                        <button type="submit"
                                class="btn btn-outline-primary btn-spinner float-end"
                                aria-label="Confirm"
                                button-spinner>
                            Add
                        </button>
                    </div>
                </div>
            </form>
        </div>
    </div>
</div>

<div class="row">
    <div class="modal fade"
         id="updateBackToBackModal"
         tabindex="-1"
         role="dialog"
         aria-labelledby="updateBackToBackModalLabel">
        <div class="modal-dialog modal-dialog-scrollable" role="document">
            <form id="backToBackUpdateForm"
                  asp-controller="PerformerManagement"
                  asp-action="UpdateAgeGroupBackToBackBranches"
                  method="post"
                  role="form" style="display:inline">
                <input asp-for="PaginateModel.CurrentPage" type="hidden" />
                <input asp-for="AgeGroup.Id" type="hidden" />
                <input asp-for="BackToBackBranchesString" type="hidden" />
                <div class="modal-content">
                    <div class="modal-header">
                        <h1 class="modal-title h4" id="updateBackToBackModalLabel">
                            Update Back to Back Branches
                        </h1>
                        <button type="button"
                                class="btn-close"
                                data-bs-dismiss="modal"
                                aria-label="Close dialog">
                        </button>

                    </div>
                    <div class="modal-body">
                        @foreach (var system in Model.Systems)
                        {
                            <strong>@system.Name</strong>
                            @foreach (var branch in system.Branches)
                            {
                                <div>
                                    <input id="@($"branch{branch.Id}")"
                                           class="branchSelector"
                                           data-id="@branch.Id" type="checkbox" />
                                    <label for="@($"branch{branch.Id}")">@branch.Name</label>
                                </div>
                            }
                            <br />
                        }
                    </div>
                    <div class="modal-footer">
                        <button type="button"
                                class="btn btn-outline-secondary"
                                data-bs-dismiss="modal">
                            Cancel
                        </button>
                        <button type="submit"
                                class="btn btn-outline-primary"
                                aria-label="Confirm"
                                button-spinner>
                            Save
                        </button>
                    </div>
                </div>
            </form>
        </div>
    </div>
</div>

<div class="row">
    <div class="modal fade"
         id="deleteModal"
         tabindex="-1"
         role="dialog"
         aria-labelledby="deleteModalLabel">
        <div class="modal-dialog" role="document">
            <form asp-controller="PerformerManagement"
                  asp-action="DeleteAgeGroup"
                  method="post"
                  role="form"
                  style="display:inline">
                <input asp-for="PaginateModel.CurrentPage" type="hidden" />
                <input asp-for="AgeGroup.Id" type="hidden" />
                <input asp-for="AgeGroup.Name" type="hidden" />
                <div class="modal-content">
                    <div class="modal-header">
                        <h1 class="modal-title h4" id="deleteModalLabel">Delete Age Group</h1>
                        <button type="button"
                                class="btn-close"
                                data-bs-dismiss="modal"
                                aria-label="Close dialog">
                        </button>
                    </div>
                    <div class="modal-body p-0">
                        <div class="modal-body d-flex align-items-stretch">
                            <span class="fas fa-exclamation-triangle fa-lg text-danger pt-2 me-3"
                                  aria-hidden="true"></span>
                            <span id="modal-text"></span>
                        </div>
                    </div>
                    <div class="modal-footer">
                        <button type="button"
                                class="btn btn-outline-secondary"
                                data-bs-dismiss="modal"
                                style="margin-right: 1em;">
                            Cancel
                        </button>
                        <button type="submit"
                                class="btn btn-outline-danger btn-spinner float-end"
                                aria-label="Confirm"
                                button-spinner>
                            <span class="fas fa-times fa-fw" aria-hidden="true"></span>
                            Delete
                        </button>
                    </div>
                </div>
            </form>
        </div>
    </div>
</div>

@section scripts {
    <script>
        $("#updateBackToBackModal").on("show.bs.modal", function (e) {
            let button = $(e.relatedTarget);
            let id = button.data("id");
            let name = button.data("name");
            let branchIds = button.data("branchids").toString();
            let modal = $(this);
            modal.find("#AgeGroup_Id").val(id);
            modal.find("#AgeGroup_Name").val(name);
            modal.find(".branchSelector").prop("checked", false);
            $.each(branchIds.split(","), function (_, value) {
                modal.find("#branch" + value).prop("checked", true);
            });
        });

        $("#backToBackUpdateForm").on("submit", function (e) {
            let backToBackBranches = $(".branchSelector:checked").map(function () {
                return $(this).data("id");
            }).get();
            $("#BackToBackBranchesString").val(JSON.stringify(backToBackBranches));
        });

        $("#deleteModal").on("show.bs.modal", function (e) {
            let button = $(e.relatedTarget);
            let id = button.data("id");
            let name = button.data("name");
            let modal = $(this);
            modal.find("#modal-text").html("Are you sure you wish to delete the Age Group: <strong>" + name + "</strong>?");
            modal.find("#AgeGroup_Id").val(id);
            modal.find("#AgeGroup_Name").val(name);
        });

        /**
        *
        * The following convert contrast using relative luminence instead of hue as per WCAG 2.1
        *
        * Necessary steps:
        *
        * 1. Parse each selected color into 8-bit sRGV chabbeks, then normalize to [0,1]:
        *      c_srgb = c8/255
        *
        * 2. Convert each normalized sRGB channel to linear-light (undo gamma):
        *      if c_srgb <= 0.04045:
        *          c_lin = c_srgb / 12.92
        *      else:
        *          c_lin = ((c_srgb + 0.055) / 1.055) ^2.4
        *
        * 3. Compute L (relative luminance) for each color:
        *      L = 0.2126*R_lin + 0.7152*G_lin + 0.0722*B_lin
        *
        * 4. Compute contrast ratio:
        *      ratio = (L1 + 0.05) / (L2 + 0.05)
        *    where L1 is lighter and L2 is darker
        *
        *
        * 5. This is then expressed as a ratio
        */

        function hexToRgb(hex) {
            if (!hex) return null;
            const h = String(hex).trim().replace(/^#/, "");
            if (!/^[0-9a-fA-F]{6}$/.test(h)) return null;

            return {
                r: parseInt(h.slice(0, 2), 16),
                g: parseInt(h.slice(2, 4), 16),
                b: parseInt(h.slice(4, 6), 16),
            };
        }

        function srgb8ToLinear(c8) {
            const c = c8 / 255;
            return c <= 0.04045 ? c / 12.92 : Math.pow((c + 0.055) / 1.055, 2.4);
        }

        function relativeLuminance(hex) {
            const rgb = typeof hex === "string" ? hexToRgb(hex) : hex;
            if (!rgb) return null;

            const R = srgb8ToLinear(rgb.r);
            const G = srgb8ToLinear(rgb.g);
            const B = srgb8ToLinear(rgb.b);

            return 0.2126 * R + 0.7152 * G + 0.0722 * B;
        }

        function contrastRatio(colorA, colorB) {
            const LA = relativeLuminance(colorA);
            const LB = relativeLuminance(colorB);
            if (LA == null || LB == null) return null;

            const lighter = Math.max(LA, LB);
            const darker = Math.min(LA, LB);

            return (lighter + 0.05) / (darker + 0.05);
        }

        function meetsMinRatio(colorA, colorB, minRatio = 4.5) {
            const ratio = contrastRatio(colorA, colorB);
            return ratio != null && ratio >= minRatio;
        }

        const WCAG_MIN_RATIO = 4.5;
        // bs-badge-color is white by default
        const BACKGROUND_COLOR = "#ffffff";

        function updateContrastStatus($modal, fgHex, bgHex) {
            const ratio = contrastRatio(fgHex, bgHex);

            const $ratio = $modal.find(".contrast-ratio");
            const $pass = $modal.find(".contrast-pass");

            if (ratio == null) {
                $ratio.text("–");
                $pass.text("").removeClass("text-success text-danger");
                return { ratio: null, passes: false };
            }

            const passes = ratio >= WCAG_MIN_RATIO;
            $ratio.text(ratio.toFixed(2) + ":1");
            $pass
                .text(passes ? "Pass (meets 4.5:1)" : "Fail (below 4.5:1)")
                .toggleClass("text-success", passes)
                .toggleClass("text-danger", !passes);

            return { ratio, passes };
        }

        function bindAgeGroupContrast() {
            const $modal = $("#addModal");
            const $input = $modal.find("#AgeGroup_IconColor");

            function recompute() {
                updateContrastStatus($modal, $input.val(), BACKGROUND_COLOR);
            }

            $input.on("change", recompute);
            $input.on("input", recompute);
            $modal.on("shown.bs.modal", recompute);
        }

        bindAgeGroupContrast();
    </script>
}