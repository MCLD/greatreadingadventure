@model GRA.Controllers.ViewModel.MissionControl.PerformerManagement.AgeGroupsListViewModel

@await Html.PartialAsync("_PerformerManagementPartial")

<div class="row my-4">
    <div class="col-12 col-md-8 offset-md-2 col-xl-6 offset-xl-3">
        <a class="btn btn-outline-primary"
           data-bs-toggle="modal"
           data-bs-target="#addModal">Add an Age Group</a>
    </div>
</div>

<div class="row">
    <div class="col-12 col-md-8 offset-md-2 col-xl-6 offset-xl-3">
        @if (Model.AgeGroups.Count == 0)
        {
            <div class="alert alert-warning">No Age Groups</div>
        }
        else
        {
            <div>
                <table class="table table-sm table-bordered table-striped">
                    <thead>
                        <tr>
                            <th>Name</th>
                            <th>Color</th>
                            <th>
                                Contrast
                                (min. @GRA.Utility.ColorConstants.Wcag21AaContrastRatioMinimum:1)
                            </th>
                            <th>Back to Back Branches</th>
                            <th>&nbsp;</th>
                        </tr>
                    </thead>
                    <tbody>
                        @foreach (var AgeGroup in Model.AgeGroups)
                        {
                            <tr>
                                <td>
                                    @AgeGroup.Name
                                </td>
                                <td class="text-center">
                                    <span class="fas fa-square fa-2x"
                                          style="color: @AgeGroup.IconColor"></span>
                                </td>
                                <td class="text-center">
                                    <span class="badge @(AgeGroup.MeetsWCAG21AAContrastRequirement ? "text-bg-success" : "text-bg-danger") me-2">AA</span>
                                    <span>@($"{AgeGroup.ContrastRatio:n1}:1")</span>
                                </td>
                                <td>
                                    <div class="d-flex justify-content-between">
                                        <span class="ms-1">@AgeGroup.BackToBackBranchIds.Count</span>
                                        <button type="button"
                                                class="btn btn-outline-primary btn-sm me-1"
                                                data-bs-toggle="modal"
                                                data-bs-target="#updateBackToBackModal"
                                                data-id="@AgeGroup.Id"
                                                data-name="@AgeGroup.Name"
                                                data-branchids="@string.Join(",", AgeGroup.BackToBackBranchIds)">
                                            <span aria-hidden="true"
                                                  class="fas fa-list fa-fw"></span>
                                        </button>
                                    </div>
                                </td>
                                <td class="text-center">
                                    <button type="button"
                                            class="btn btn-outline-danger btn-sm"
                                            data-bs-toggle="modal"
                                            data-bs-target="#deleteModal"
                                            data-id="@AgeGroup.Id"
                                            data-name="@AgeGroup.Name">
                                        <span class="fas fa-times fa-fw" aria-hidden="true"></span>
                                    </button>
                                </td>
                            </tr>
                        }
                    </tbody>
                </table>
            </div>
            <paginate paginateModel="@Model.PaginateModel"></paginate>
        }
    </div>
</div>

<div class="row">
    <div class="modal fade"
         id="addModal"
         tabindex="-1"
         role="dialog"
         aria-labelledby="addModalLabel">
        <div class="modal-dialog" role="document">
            <form asp-controller="PerformerManagement"
                  asp-action="AddAgeGroup"
                  method="post"
                  role="form"
                  style="display:inline">
                <input asp-for="PaginateModel.CurrentPage" type="hidden" />
                <div class="modal-content">
                    <div class="modal-header">
                        <h1 class="modal-title h4" id="addModalLabel">Add Age Group</h1>
                        <button type="button"
                                class="btn-close"
                                data-bs-dismiss="modal"
                                aria-label="Close dialog">
                        </button>
                    </div>
                    <div class="modal-body">
                        <div class="mb-3">
                            <label asp-for="AgeGroup.Name" class="col-form-label"></label>
                            <input asp-for="AgeGroup.Name" class="form-control" />
                            <span asp-validation-for="AgeGroup.Name" class="text-danger"></span>
                        </div>
                        <div class="mb-3">
                            <label asp-for="AgeGroup.IconColor" class="col-form-label"></label>
                            <description gra-description-for="AgeGroup.IconColor"></description>
                            <br />
                            <input asp-for="AgeGroup.IconColor" type="color" />
                            <div class="contrast-status">
                                <label class="contrast-label">
                                    Contrast ratio <em>
                                        (min.
                                        @GRA.Utility.ColorConstants.Wcag21AaContrastRatioMinimum:1)
                                    </em>:
                                    <span class="contrast-ratio fw-bold"></span>
                                </label>
                                <span class="contrast-pass badge ms-2">AA</span>
                            </div>
                            <span asp-validation-for="AgeGroup.IconColor"
                                  class="text-danger"></span>
                        </div>
                    </div>
                    <div class="modal-footer">
                        <button type="button"
                                class="btn btn-outline-secondary"
                                data-bs-dismiss="modal">
                            Cancel
                        </button>
                        <button type="submit"
                                class="btn btn-outline-primary add-button"
                                aria-label="Confirm"
                                button-spinner>
                            Add
                        </button>
                    </div>
                </div>
            </form>
        </div>
    </div>
</div>

<div class="row">
    <div class="modal fade"
         id="updateBackToBackModal"
         tabindex="-1"
         role="dialog"
         aria-labelledby="updateBackToBackModalLabel">
        <div class="modal-dialog modal-dialog-scrollable" role="document">
            <form id="backToBackUpdateForm"
                  asp-controller="PerformerManagement"
                  asp-action="UpdateAgeGroupBackToBackBranches"
                  method="post"
                  role="form" style="display:inline">
                <input asp-for="PaginateModel.CurrentPage" type="hidden" />
                <input asp-for="AgeGroup.Id" type="hidden" />
                <input asp-for="BackToBackBranchesString" type="hidden" />
                <div class="modal-content">
                    <div class="modal-header">
                        <h1 class="modal-title h4" id="updateBackToBackModalLabel">
                            Update Back to Back Branches
                        </h1>
                        <button type="button"
                                class="btn-close"
                                data-bs-dismiss="modal"
                                aria-label="Close dialog">
                        </button>

                    </div>
                    <div class="modal-body">
                        @foreach (var system in Model.Systems)
                        {
                            <strong>@system.Name</strong>
                            @foreach (var branch in system.Branches)
                            {
                                <div>
                                    <input id="@($"branch{branch.Id}")"
                                           class="branchSelector"
                                           data-id="@branch.Id" type="checkbox" />
                                    <label for="@($"branch{branch.Id}")">@branch.Name</label>
                                </div>
                            }
                            <br />
                        }
                    </div>
                    <div class="modal-footer">
                        <button type="button"
                                class="btn btn-outline-secondary"
                                data-bs-dismiss="modal">
                            Cancel
                        </button>
                        <button type="submit"
                                class="btn btn-outline-primary"
                                aria-label="Confirm"
                                button-spinner>
                            Save
                        </button>
                    </div>
                </div>
            </form>
        </div>
    </div>
</div>

<div class="row">
    <div class="modal fade"
         id="deleteModal"
         tabindex="-1"
         role="dialog"
         aria-labelledby="deleteModalLabel">
        <div class="modal-dialog" role="document">
            <form asp-controller="PerformerManagement"
                  asp-action="DeleteAgeGroup"
                  method="post"
                  role="form"
                  style="display:inline">
                <input asp-for="PaginateModel.CurrentPage" type="hidden" />
                <input asp-for="AgeGroup.Id" type="hidden" />
                <input asp-for="AgeGroup.Name" type="hidden" />
                <div class="modal-content">
                    <div class="modal-header">
                        <h1 class="modal-title h4" id="deleteModalLabel">Delete Age Group</h1>
                        <button type="button"
                                class="btn-close"
                                data-bs-dismiss="modal"
                                aria-label="Close dialog">
                        </button>
                    </div>
                    <div class="modal-body p-0">
                        <div class="modal-body d-flex align-items-stretch">
                            <span class="fas fa-exclamation-triangle fa-lg text-danger pt-2 me-3"
                                  aria-hidden="true"></span>
                            <span id="modal-text"></span>
                        </div>
                    </div>
                    <div class="modal-footer">
                        <button type="button"
                                class="btn btn-outline-secondary"
                                data-bs-dismiss="modal"
                                style="margin-right: 1em;">
                            Cancel
                        </button>
                        <button type="submit"
                                class="btn btn-outline-danger btn-spinner float-end"
                                aria-label="Confirm"
                                button-spinner>
                            <span class="fas fa-times fa-fw" aria-hidden="true"></span>
                            Delete
                        </button>
                    </div>
                </div>
            </form>
        </div>
    </div>
</div>

@section scripts {
    <script>
        $("#updateBackToBackModal").on("show.bs.modal", function (e) {
            let button = $(e.relatedTarget);
            let id = button.data("id");
            let name = button.data("name");
            let branchIds = button.data("branchids").toString();
            let modal = $(this);
            modal.find("#AgeGroup_Id").val(id);
            modal.find("#AgeGroup_Name").val(name);
            modal.find(".branchSelector").prop("checked", false);
            $.each(branchIds.split(","), function (_, value) {
                modal.find("#branch" + value).prop("checked", true);
            });
        });

        $("#backToBackUpdateForm").on("submit", function (e) {
            let backToBackBranches = $(".branchSelector:checked").map(function () {
                return $(this).data("id");
            }).get();
            $("#BackToBackBranchesString").val(JSON.stringify(backToBackBranches));
        });

        $("#deleteModal").on("show.bs.modal", function (e) {
            let button = $(e.relatedTarget);
            let id = button.data("id");
            let name = button.data("name");
            let modal = $(this);
            modal.find("#modal-text")
                .html(`Are you sure you wish to delete the Age Group: <strong>${name}</strong>?`);
            modal.find("#AgeGroup_Id").val(id);
            modal.find("#AgeGroup_Name").val(name);
        });

        const enforceA11y = "@Model.EnforceA11y";
        const graContrastUrl = new URL(`${location.origin}@Url.Action(nameof(HomeController.ContrastRatio), HomeController.Name, new { area = HomeController.Area })`);

        if(typeof graContrastUrl !== 'undefined' && graContrastUrl) {
            // returns an object with these properties:
            // ratio = what the contrast ratio is
            // meetsWCAG21AA = meets the WCAG 2.1 AA contrast requirement
            function contrastRatio(rgbHexadecimal1, rgbHexadecimal2) {
                graContrastUrl.search = new URLSearchParams({
                    rgbHexadecimal1: rgbHexadecimal1,
                    rgbHexadecimal2: rgbHexadecimal2
                });

                try {
                    return fetch(graContrastUrl).then((response) => response.json());
                }
                catch (e) {
                    console.error(`An issue occured checking contrast: ${e}`);
                    alert(`An issue occured checking contrast: ${e}`);
                }
            }

            function updateContrastStatus($modal, rgbHexadecimal1, rgbHexadecimal2) {
                contrastRatio(rgbHexadecimal1, rgbHexadecimal2)
                    .then((contrastResult) => {
                        const $ratio = $modal.find(".contrast-ratio");
                        const $pass = $modal.find(".contrast-pass");
                        const $add = $modal.find(".add-button");
                        const $contrastLabel = $modal.find(".contrast-label");

                        if (contrastResult.ratio == null) {
                            $ratio.text("–");
                            $pass.text("").removeClass("text-success text-danger");
                        }

                        $ratio.text(`${contrastResult.ratio.toFixed(1)}:1`);
                        $pass.toggleClass("text-bg-success", contrastResult.meetsWCAG21AA)
                            .toggleClass("text-bg-danger", !contrastResult.meetsWCAG21AA);

                        if(enforceA11y && enforceA11y === "True") {
                            $add.toggleClass("btn-outline-success", contrastResult.meetsWCAG21AA)
                                .toggleClass("btn-outline-danger", !contrastResult.meetsWCAG21AA);
                            $contrastLabel.toggleClass("text-danger", !contrastResult.meetsWCAG21AA);
                            if(contrastResult.meetsWCAG21AA) {
                                $add.attr("disabled", null);
                            }
                            else {
                                $add.attr("disabled", "disabled");
                            }
                        }
                    });
            }

            const whiteBackgroundColor = "@GRA.Utility.ColorConstants.WhiteBackground";

            function bindAgeGroupContrast() {
                const $modal = $("#addModal");
                const $input = $modal.find("#AgeGroup_IconColor");

                if ($modal.length === 0 || $input.length === 0) {
                    return;
                }

                function recompute() {
                    updateContrastStatus($modal, $input.val(), whiteBackgroundColor);
                }

                $input.off("change.contrast input.contrast");
                $modal.off("shown.bs.modal.contrast");

                $input.on("change.contrast", recompute);
                $input.on("input.contrast", recompute);
                $modal.on("shown.bs.modal.contrast", recompute);

                recompute();
            }
            bindAgeGroupContrast();
        }
    </script>
}